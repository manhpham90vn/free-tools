# =============================================================================
# Free Antigravity - Environment Configuration
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# TARGET PROVIDER ENDPOINT
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for target LLM provider (required)
# Claude: https://api.anthropic.com
# OpenAI: https://api.openai.com/v1
# Ollama: http://localhost:11434
ANTHROPIC_BASE_URL=

# API key for the target provider (required)
# Claude: Anthropic API Key (sk-ant-...)
# OpenAI: OpenAI API Key (sk-...)
# Ollama: any value (not used)
ANTHROPIC_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Override default model
# ─────────────────────────────────────────────────────────────────────────────

# Default model (can also be set in config.yaml)
# DEFAULT_MODEL=claude-sonnet-4-6
